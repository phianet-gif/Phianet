        // INTERACTIVE DYNAMIC MATRIX ELEMENT FILLERS (CLASS DROPDOWN VARIATIONS)
        function populateClassesBySection() {
            const sectionSelected = document.getElementById('p-section').value;
            const classSelectDOM = document.getElementById('p-class');
            
            classSelectDOM.innerHTML = '';
            
            if (!sectionSelected) {
                classSelectDOM.innerHTML = '<option value="">-- Choose Section First --</option>';
                return;
            }

            CLASS_LOOKUP[sectionSelected].forEach(classLevel => {
                const opt = document.createElement('option');
                opt.value = classLevel;
                opt.innerText = classLevel;
                classSelectDOM.appendChild(opt);
            });

            evaluateDynamicInvoice();
        }

        // INTERACTIVE REAL-TIME FINANCIAL LEDGER VARIABLE EVALUATOR
        function evaluateDynamicInvoice() {
            const section = document.getElementById('p-section').value;
            const residence = document.getElementById('p-residence').value;
            
            if (!section || !residence) {
                document.getElementById('f-base').value = 0;
                document.getElementById('f-total-invoice').value = 0;
                document.getElementById('f-balance').value = 0;
                return;
            }

            // Extract values derived from static configuration engine matrix
            const baseTuition = FEE_STRUCTURE[section][residence];
            document.getElementById('f-base').value = `UGX ${baseTuition.toLocaleString()}`;

            // Aggregate dynamic secondary structural checkbox outlays
            let addOnsGross = 0;
            const addOnIDs = ['add-uniform', 'add-sweater', 'add-report', 'add-dev', 'add-med'];
            addOnIDs.forEach(id => {
                const cb = document.getElementById(id);
                if (cb && cb.checked) {
                    addOnsGross += parseInt(cb.value);
                }
            });

            const totalInvoiceGross = baseTuition + addOnsGross;
            document.getElementById('f-total-invoice').value = totalInvoiceGross; // Store literal integer for downstream compute evaluation

            const totalPaidAmount = parseInt(document.getElementById('f-paid').value) || 0;
            const absoluteDeficitOutstanding = totalInvoiceGross - totalPaidAmount;

            // Render numeric changes visibly formatted
            document.getElementById('f-total-invoice').value = `UGX ${totalInvoiceGross.toLocaleString()}`;
            document.getElementById('f-balance').value = `UGX ${absoluteDeficitOutstanding.toLocaleString()}`;
            
            // Direct structural color feedback loops based on metrics status
            if (absoluteDeficitOutstanding > 0) {
                document.getElementById('f-balance').style.backgroundColor = '#fee2e2';
                document.getElementById('f-balance').style.color = '#b91c1c';
            } else {
                document.getElementById('f-balance').style.backgroundColor = '#d1fae5';
                document.getElementById('f-balance').style.color = '#065f46';
            }
        }

        // STATE SYNCHRONIZATION AND METRIC REDUCER ENGINE
        function recalculateWholeSystemState() {
            // A. Compute KPI Metrics via Array Reducers
            const countTotalPupils = STATE.pupils.length;
            const countNursery = STATE.pupils.filter(p => p.section === 'Nursery').length;
            const countPrimary = STATE.pupils.filter(p => p.section === 'Primary').length;
            const countStaff = STATE.staff.length;

            let expectedRevenueGross = 0;
            let realizedRevenueCollected = 0;
            let outstandingArrearsDeficit = 0;

            STATE.pupils.forEach(p => {
                expectedRevenueGross += p.invoice;
                realizedRevenueCollected += p.paid;
                outstandingArrearsDeficit += p.balance;
            });

            let combinedExpensesOutlay = 0;
            STATE.expenses.forEach(e => combinedExpensesOutlay += e.amount);

            const systemicNetSurplusProfit = realizedRevenueCollected - combinedExpensesOutlay;

            // B. Direct UI Injection DOM bindings
            document.getElementById('kpi-total-pupils').innerText = countTotalPupils;
            document.getElementById('kpi-pupil-breakdown').innerText = `Nursery: ${countNursery} | Primary: ${countPrimary}`;
            document.getElementById('kpi-total-staff').innerText = countStaff;
            document.getElementById('kpi-total-collected').innerText = `UGX ${realizedRevenueCollected.toLocaleString()}`;
            document.getElementById('kpi-total-arrears').innerText = `UGX ${outstandingArrearsDeficit.toLocaleString()}`;

            // C. Synchronize Accountant Ledger Dashboard Metrics Panel Card Component Viewports
            document.getElementById('fin-gross-revenue').innerText = `UGX ${expectedRevenueGross.toLocaleString()}`;
            document.getElementById('fin-gross-collected').innerText = `UGX ${realizedRevenueCollected.toLocaleString()}`;
            document.getElementById('fin-gross-arrears').innerText = `UGX ${outstandingArrearsDeficit.toLocaleString()}`;
            document.getElementById('fin-gross-expenses').innerText = `UGX ${combinedExpensesOutlay.toLocaleString()}`;
            
            const netProfitDOM = document.getElementById('fin-net-profit');
            netProfitDOM.innerText = `Net Structural Institutional Surplus: UGX ${systemicNetSurplusProfit.toLocaleString()}`;
            if(systemicNetSurplusProfit >= 0) {
                netProfitDOM.style.backgroundColor = "#f0fdf4"; netProfitDOM.style.color = "#166534";
            } else {
                netProfitDOM.style.backgroundColor = "#fef2f2"; netProfitDOM.style.color = "#991b1b";
            }

            // D. Populate and Render Structural Data Log Tables Dynamic Arrays Loop Rows
            renderFinancialTablesAndLogs();
            renderDemographicsBars();
        }

        // LEDGER DATA AND METRIC LOG RENDER ENGINE CONTEXTS
        function renderFinancialTablesAndLogs() {
            // Student Finance Audit Ledger View Injection
            const studentFinBody = document.getElementById('studentFinanceTableBody');
            studentFinBody.innerHTML = '';
