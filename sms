        // RENDER INTERACTIVE ENROLLMENT METRIC DEMOGRAPHICS PROGRESS BAR COMPONENTS
        function renderDemographicsBars() {
            const container = document.getElementById('demographics-container');
            container.innerHTML = '';

            const combinedAllClassesArray = [...CLASS_LOOKUP.Nursery, ...CLASS_LOOKUP.Primary];
            const sampleMaxBaselineScaling = 10; // Normalized ceiling reference for progress UI rendering component representation

            combinedAllClassesArray.forEach(classLevel => {
                const matchingCount = STATE.pupils.filter(p => p.level === classLevel).length;
                const evaluatedPercentageWidth = Math.min((matchingCount / sampleMaxBaselineScaling) * 100, 100);
                const isNurseryLevelElement = CLASS_LOOKUP.Nursery.includes(classLevel);

                const blockGroup = document.createElement('div');
                blockGroup.className = `progress-group ${isNurseryLevelElement ? 'nursery-level' : ''}`;
                blockGroup.innerHTML = `
                    <div class="progress-label">
                        <span>${classLevel}</span>
                        <strong>${matchingCount} Pupils registered</strong>
                    </div>
                    <div class="progress-bar-bg">
                        <div class="progress-bar-fill" style="width: ${evaluatedPercentageWidth || 3}%;"></div>
                    </div>
                `;
                container.appendChild(blockGroup);
            });
        }

        // POST AND PROCESS REGISTRATION TRANSACTION ACTIONS (EVENT HANDLERS)
        function processPupilRegistration(event) {
            event.preventDefault();

            // Extract exact raw components dynamically out of DOM form state variables
            const section = document.getElementById('p-section').value;
            const residence = document.getElementById('p-residence').value;
            const baseTuition = FEE_STRUCTURE[section][residence];

            let addOnsGross = 0;
            const addOnIDs = ['add-uniform', 'add-sweater', 'add-report', 'add-dev', 'add-med'];
            addOnIDs.forEach(id => {
                const cb = document.getElementById(id);
                if (cb && cb.checked) addOnsGross += parseInt(cb.value);
            });

            const calculatedGrossInvoicedAmount = baseTuition + addOnsGross;
            const inputRealizedDisbursedDeposit = parseInt(document.getElementById('f-paid').value) || 0;
            const outstandingComputedDeficitArrears = calculatedGrossInvoicedAmount - inputRealizedDisbursedDeposit;

            const newPupilEntity = {
                name: document.getElementById('p-name').value,
                dob: document.getElementById('p-dob').value,
                gender: document.getElementById('p-gender').value,
                section: section,
                level: document.getElementById('p-class').value,
                stream: document.getElementById('p-stream').value,
                residence: residence,
                invoice: calculatedGrossInvoicedAmount,
                paid: inputRealizedDisbursedDeposit,
                balance: outstandingComputedDeficitArrears
            };

            // Push into main system core database storage array memory reference
            STATE.pupils.push(newPupilEntity);

            // Reset Form Fields state and recalculate dashboard downstream pipeline impacts
            document.getElementById('pupilForm').reset();
            document.getElementById('p-class').innerHTML = '<option value="">-- Choose Section First --</option>';
            
            recalculateWholeSystemState();
            alert(`Database Entry Complete: ${newPupilEntity.name} has been enrolled successfully into the system.`);
            switchTab('dashboard');
        }

