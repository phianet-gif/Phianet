                            <input type="radio" name="att-status-${index}" value="Absent"> Absent
                        </label>
                        <label style="font-size:0.85rem; font-weight:600; color:var(--text-muted);">
                            <input type="radio" name="att-status-${index}" value="Excused"> Excused
                        </label>
                    </td>
                `;
                targetTableBodyDOM.appendChild(row);
            });
        }

        // ACADEMIC ASSESSMENT GRADING DATA ENTRY MODULE ARCHITECTURE SHEET BUILDER
        function renderGradingClassSheet() {
            const selectedClass = document.getElementById('grading-class-select').value;
            const targetTableBodyDOM = document.getElementById('gradingTableBody');

            targetTableBodyDOM.innerHTML = '';

            const filteredClassPupils = STATE.pupils.filter(p => p.level === selectedClass);

            if (filteredClassPupils.length === 0) {
                targetTableBodyDOM.innerHTML = `<tr><td colspan="3" style="text-align:center; color:var(--text-muted);">No students currently registered in ${selectedClass} within database system state pool.</td></tr>`;
                return;
            }

            filteredClassPupils.forEach((pupil, index) => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td><strong>${pupil.name}</strong></td>
                    <td>
                        <input type="number" min="0" max="100" placeholder="Score Input" 
                               id="score-input-${index}" 
                               style="width:100px; padding:0.4rem; border:1px solid var(--border-color); border-radius:var(--radius-md);"
                               oninput="calculateDynamicGradeAlphaElement(${index})">
                    </td>
                    <td><span id="grade-badge-output-${index}" class="badge" style="background:#e2e8f0; color:var(--text-main);">Unassigned Score</span></td>
                `;
                targetTableBodyDOM.appendChild(row);
            });
        }

        // DYNAMIC SCORE CALCULATOR EVALUATOR SYSTEM scale BASELINE RULE ENGINE
        function calculateDynamicGradeAlphaElement(indexSelectorKey) {
            const scoreInputValueRaw = document.getElementById(`score-input-${indexSelectorKey}`).value;
            const targetBadgeOutputDOM = document.getElementById(`grade-badge-output-${indexSelectorKey}`);
            
            if (scoreInputValueRaw === '') {
                targetBadgeOutputDOM.innerText = "Unassigned Score";
                targetBadgeOutputDOM.className = "badge";
                targetBadgeOutputDOM.style.backgroundColor = "#e2e8f0";
                targetBadgeOutputDOM.style.color = "var(--text-main)";
                return;
            }

            const numericScore = parseInt(scoreInputValueRaw);
            let evaluationAlphaGradeString = "F";
            let cssStyleClassBadgeType = "badge-danger";

            // Standard Ugandan Primary Grading Scale Parameter Implementations (D1 to F9 equivalents mapped onto alpha arrays)
            if (numericScore >= 90) { evaluationAlphaGradeString = "D1 [Excellent]"; cssStyleClassBadgeType = "badge-success"; }
            else if (numericScore >= 80) { evaluationAlphaGradeString = "D2 [Very Good]"; cssStyleClassBadgeType = "badge-success"; }
            else if (numericScore >= 70) { evaluationAlphaGradeString = "C3 [Good]"; cssStyleClassBadgeType = "badge-primary"; }
            else if (numericScore >= 60) { evaluationAlphaGradeString = "C4 [Credit]"; cssStyleClassBadgeType = "badge-primary"; }
            else if (numericScore >= 50) { evaluationAlphaGradeString = "C5 [Credit]"; cssStyleClassBadgeType = "badge-nursery"; }
            else if (numericScore >= 45) { evaluationAlphaGradeString = "C6 [Credit]"; cssStyleClassBadgeType = "badge-nursery"; }
            else if (numericScore >= 40) { evaluationAlphaGradeString = "P7 [Pass]"; cssStyleClassBadgeType = "badge-nursery"; }
            else if (numericScore >= 35) { evaluationAlphaGradeString = "P8 [Pass]"; cssStyleClassBadgeType = "badge-nursery"; }
            else { evaluationAlphaGradeString = "F9 [Fail]"; cssStyleClassBadgeType = "badge-danger"; }

            targetBadgeOutputDOM.innerText = evaluationAlphaGradeString;
            targetBadgeOutputDOM.className = `badge ${cssStyleClassBadgeType}`;
        }

        // SYSTEM HARDWARE EVENT INITIALIZER ON CONTENT LOAD
        window.addEventListener('DOMContentLoaded', () => {
            injectMockCoreData();
        });
    </script>
</body>
</html>
